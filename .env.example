# Copie este arquivo para .env e preencha com suas credenciais.
# NUNCA commite o arquivo .env.

# URL base da instância Jira (sem barra no final)
JIRA_URL=https://suaempresa.atlassian.net

# E-mail da conta Jira usada para autenticação
JIRA_EMAIL=seu.email@empresa.com

# API Token gerado em: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=seu_token_aqui

# Boards disponíveis no formato JSON (id, project key, nome de exibição)
JIRA_BOARDS=[{"id":123,"project":"KEY","name":"Nome do Board"}]

# ID do board padrão ao abrir o dashboard
JIRA_DEFAULT_BOARD=123

# URL do ambiente de QA para monitoramento de status (opcional)
QA_ENV_URL=https://seu-ambiente-qa.com/
